<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Teacher View — Class <%= code %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <meta http-equiv="refresh" content="10">
</head>
<body class="teacher-bg">

  <!-- Navbar -->
  <nav class="navbar navbar-dark teacher-nav px-3 py-2">
    <a class="navbar-brand fw-bold" href="/">🤫 Silent Q&A</a>
    <div class="d-flex align-items-center gap-3">
      <span class="badge teacher-badge fs-6">
        Teacher Dashboard &nbsp;|&nbsp; Class: <span class="mono-text"><%= code %></span>
      </span>
      <span class="text-white-50 small">Auto-refreshes every 10s</span>
    </div>
  </nav>

  <div class="container py-4">

    <!-- Stats Row -->
    <div class="row g-3 mb-4">
      <div class="col-6 col-md-3">
        <div class="stat-card text-center p-3">
          <div class="stat-number"><%= questions.length %></div>
          <div class="stat-label">Total Questions</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card text-center p-3">
          <div class="stat-number text-warning"><%= questions.filter(q => !q.answered).length %></div>
          <div class="stat-label">Unanswered</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card text-center p-3">
          <div class="stat-number text-success"><%= questions.filter(q => q.answered).length %></div>
          <div class="stat-label">Answered</div>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card text-center p-3">
          <div class="stat-number text-info">
            <%= questions.reduce((sum, q) => sum + q.upvotes, 0) %>
          </div>
          <div class="stat-label">Total Upvotes</div>
        </div>
      </div>
    </div>

    <!-- Share code banner -->
    <div class="share-banner mb-4 p-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <strong>Share class code with students:</strong>
        <span class="mono-text fs-4 ms-2 class-code-display"><%= code %></span>
      </div>
      <button class="btn btn-sm btn-outline-light" onclick="copyCode('<%= code %>')">📋 Copy Code</button>
    </div>

    <!-- Bulk actions -->
    <% if (questions.some(q => q.answered)) { %>
    <div class="d-flex justify-content-end mb-3">
      <form action="/teacher/<%= code %>/clear" method="POST"
            onsubmit="return confirm('Clear all answered questions?')">
        <input type="hidden" name="pin" value="<%= pin %>"/>
        <button type="submit" class="btn btn-sm btn-outline-danger">🗑 Clear Answered</button>
      </form>
    </div>
    <% } %>

    <!-- Questions -->
    <% if (questions.length === 0) { %>
      <div class="empty-state text-center py-5">
        <div class="empty-icon">📭</div>
        <p class="text-muted mt-3">No questions yet. Students will start posting soon!</p>
      </div>
    <% } %>

    <% questions.forEach(function(q) { %>
      <div class="card teacher-question-card mb-3 <%= q.answered ? 'answered' : '' %>">
        <div class="card-body p-3">
          <div class="d-flex align-items-start gap-3">

            <!-- Upvote count -->
            <div class="upvote-col text-center">
              <div class="upvote-display">
                <span class="upvote-arrow-static">▲</span>
                <span class="d-block fw-bold"><%= q.upvotes %></span>
              </div>
            </div>

            <!-- Content -->
            <div class="flex-grow-1">
              <p class="question-text mb-2 <%= q.answered ? 'text-muted text-decoration-line-through' : 'fw-semibold' %>">
                <%= q.text %>
              </p>
              <div class="d-flex align-items-center gap-2 flex-wrap">
                <span class="text-muted small">⏱ <%= q.timestamp %></span>
                <% if (q.answered) { %>
                  <span class="badge answered-badge">✓ Answered</span>
                <% } %>
              </div>
            </div>

            <!-- Actions -->
            <div class="action-btns d-flex gap-2 flex-shrink-0">
              <% if (!q.answered) { %>
                <form action="/teacher/<%= code %>/answer/<%= q.id %>" method="POST">
                  <input type="hidden" name="pin" value="<%= pin %>"/>
                  <button type="submit" class="btn btn-sm btn-success">✓ Answered</button>
                </form>
              <% } %>
              <form action="/teacher/<%= code %>/delete/<%= q.id %>" method="POST"
                    onsubmit="return confirm('Delete this question?')">
                <input type="hidden" name="pin" value="<%= pin %>"/>
                <button type="submit" class="btn btn-sm btn-outline-danger">🗑</button>
              </form>
            </div>

          </div>
        </div>
      </div>
    <% }); %>

  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    function copyCode(code) {
      navigator.clipboard.writeText(code).then(() => {
        const btn = event.target;
        btn.textContent = '✅ Copied!';
        setTimeout(() => btn.textContent = '📋 Copy Code', 1500);
      });
    }
  </script>
</body>
</html>
