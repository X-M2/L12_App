<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Class Not Found — Silent Q&A</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body class="hero-bg">
  <div class="container py-5 text-center">
    <div class="error-icon mt-5">🚫</div>
    <h1 class="display-5 fw-bold mt-3">Class Not Found</h1>
    <p class="text-muted lead mt-2">
      The class code <strong class="mono-text"><%= code %></strong> doesn't exist or has expired.
    </p>
    <a href="/" class="btn btn-student mt-4">← Back to Home</a>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
