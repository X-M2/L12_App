<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Silent Q&A — Home</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>

  <div class="hero-bg">
    <div class="container py-5">

      <!-- Header -->
      <div class="text-center mb-5">
        <div class="brand-badge mb-3">🤫</div>
        <h1 class="display-4 fw-bold brand-title">Silent Q&amp;A</h1>
        <p class="lead brand-sub">Ask questions anonymously. No judgment, just learning.</p>
      </div>

      <!-- Alerts -->
      <% if (typeof error !== 'undefined') { %>
        <div class="alert alert-danger alert-dismissible fade show col-md-8 mx-auto" role="alert">
          <%= error %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>
      <% if (typeof joinError !== 'undefined') { %>
        <div class="alert alert-warning alert-dismissible fade show col-md-8 mx-auto" role="alert">
          <%= joinError %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% } %>

      <!-- Cards Row -->
      <div class="row g-4 justify-content-center">

        <!-- Student Card -->
        <div class="col-md-5">
          <div class="card home-card h-100">
            <div class="card-body p-4">
              <div class="card-icon mb-3">🎓</div>
              <h4 class="fw-bold">I'm a Student</h4>
              <p class="text-muted small mb-4">Join your class and ask questions without raising your hand.</p>
              <form action="/join" method="POST">
                <div class="mb-3">
                  <label class="form-label fw-semibold">Class Code</label>
                  <input type="text" name="classCode" class="form-control form-control-lg mono-input"
                    placeholder="e.g. AB12C" maxlength="5" required autocomplete="off"/>
                </div>
                <button type="submit" class="btn btn-student w-100">Join Class →</button>
              </form>
            </div>
          </div>
        </div>

        <!-- Teacher Card -->
        <div class="col-md-5">
          <div class="card home-card h-100">
            <div class="card-body p-4">
              <div class="card-icon mb-3">📋</div>
              <h4 class="fw-bold">I'm a Teacher</h4>
              <p class="text-muted small mb-4">Create a class session and manage questions in real time.</p>
              <form action="/create" method="POST">
                <div class="mb-3">
                  <label class="form-label fw-semibold">Set a Teacher PIN</label>
                  <input type="password" name="teacherPin" class="form-control form-control-lg"
                    placeholder="Choose a PIN" required autocomplete="off"/>
                </div>
                <button type="submit" class="btn btn-teacher w-100">Create Class →</button>
              </form>
            </div>
          </div>
        </div>

      </div>

      <!-- Footer note -->
      <p class="text-center text-muted small mt-5 opacity-50">All questions are anonymous. Sessions reset on server restart.</p>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
