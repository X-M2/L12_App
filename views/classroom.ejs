<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Class <%= code %> — Silent Q&A</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=DM+Sans:wght@300;400;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="/css/style.css"/>
  <meta http-equiv="refresh" content="15">
</head>
<body class="classroom-bg">

  <!-- Navbar -->
  <nav class="navbar navbar-dark classroom-nav px-3 py-2">
    <a class="navbar-brand fw-bold" href="/">🤫 Silent Q&A</a>
    <div class="d-flex align-items-center gap-3">
      <span class="badge class-badge fs-6">Class: <span class="mono-text"><%= code %></span></span>
      <span class="text-white-50 small">Auto-refreshes every 15s</span>
    </div>
  </nav>

  <div class="container py-4">
    <div class="row g-4">

      <!-- Ask Question Panel -->
      <div class="col-lg-4">
        <div class="card ask-card sticky-top" style="top: 80px;">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-1">Ask Anonymously</h5>
            <p class="text-muted small mb-3">Your name is never shown. Ask freely.</p>
            <form action="/class/<%= code %>/ask" method="POST">
              <div class="mb-3">
                <textarea name="question" class="form-control question-input"
                  rows="4" placeholder="What's on your mind?..." required maxlength="300"></textarea>
                <div class="form-text text-end char-count">max 300 chars</div>
              </div>
              <button type="submit" class="btn btn-ask w-100">
                📨 Post Question
              </button>
            </form>
          </div>
        </div>
      </div>

      <!-- Questions Feed -->
      <div class="col-lg-8">
        <div class="d-flex align-items-center justify-content-between mb-3">
          <h5 class="fw-bold mb-0">
            Questions
            <span class="badge bg-secondary ms-2"><%= questions.length %></span>
          </h5>
          <span class="text-muted small">Most upvoted shown first</span>
        </div>

        <% if (questions.length === 0) { %>
          <div class="empty-state text-center py-5">
            <div class="empty-icon">💬</div>
            <p class="text-muted mt-3">No questions yet. Be the first to ask!</p>
          </div>
        <% } %>

        <% questions.forEach(function(q) { %>
          <div class="card question-card mb-3 <%= q.answered ? 'answered' : '' %>">
            <div class="card-body p-3">
              <div class="d-flex align-items-start gap-3">

                <!-- Upvote -->
                <div class="upvote-col text-center">
                  <% if (!q.answered) { %>
                    <form action="/class/<%= code %>/upvote/<%= q.id %>" method="POST" class="m-0">
                      <button type="submit" class="btn btn-upvote">
                        <span class="upvote-arrow">▲</span>
                        <span class="upvote-count d-block"><%= q.upvotes %></span>
                      </button>
                    </form>
                  <% } else { %>
                    <div class="upvote-placeholder">
                      <span class="text-muted">▲</span>
                      <span class="d-block text-muted small"><%= q.upvotes %></span>
                    </div>
                  <% } %>
                </div>

                <!-- Question text -->
                <div class="flex-grow-1">
                  <p class="question-text mb-1 <%= q.answered ? 'text-muted' : '' %>">
                    <%= q.text %>
                  </p>
                  <div class="d-flex gap-2 align-items-center">
                    <span class="text-muted small">⏱ <%= q.timestamp %></span>
                    <% if (q.answered) { %>
                      <span class="badge answered-badge">✓ Answered</span>
                    <% } %>
                  </div>
                </div>

              </div>
            </div>
          </div>
        <% }); %>

      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Live char counter
    const ta = document.querySelector('textarea[name="question"]');
    const counter = document.querySelector('.char-count');
    if (ta && counter) {
      ta.addEventListener('input', () => {
        const left = 300 - ta.value.length;
        counter.textContent = `${left} chars remaining`;
        counter.style.color = left < 30 ? '#dc3545' : '';
      });
    }
  </script>
</body>
</html>
